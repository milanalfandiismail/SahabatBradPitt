# ==============================================================================
# SahabatBradPitt - Environment Variables Template
# Salin file ini menjadi `.env` di root folder dan sesuaikan nilainya.
# ==============================================================================

# --- KELAS LINGKUNGAN (DEVELOPMENT VS PRODUCTION) ---
# Di development: DEBUG=True
# Di production: DEBUG=False (WAJIB!)
DEBUG=True

# Kunci rahasia Django (gunakan string acak yang panjang dan aman di production)
SECRET_KEY=your-secret-key-here

# Host yang diizinkan untuk mengakses aplikasi (pisahkan dengan koma)
# Di development: 127.0.0.1,localhost
# Di production: domain_anda.com,www.domain_anda.com,ip_server_anda
ALLOWED_HOSTS=127.0.0.1,localhost

# --- INTEGRASI API EKSTERNAL ---
# TMDB API (Wajib untuk sinkronisasi data film & aktor dari TheMovieDB)
TMDB_API_KEY=your-tmdb-api-key-here

# YouTube Data API (Opsional, digunakan sebagai fallback pencarian trailer film)
YOUTUBE_API_KEY=your-youtube-api-key-here

# Google Auth Client ID (Wajib jika menggunakan login via Google)
GOOGLE_CLIENT_ID=your-google-client-id-here

# --- SETTING LAYANAN CACHE & KEAMANAN (PRODUCTION ONLY) ---
# Redis Cache URL (Opsional, untuk clustering / performa tinggi di VPS production)
# Jika dikosongkan/tidak diisi, Django akan otomatis menggunakan FileBasedCache (django_cache/)
# REDIS_URL=redis://127.0.0.1:6379/1

# HTTPS SSL Redirect (Default: False)
# Atur menjadi True jika server production Anda menggunakan HTTPS penuh agar HTTP otomatis dialihkan ke HTTPS.
SECURE_SSL_REDIRECT=False

